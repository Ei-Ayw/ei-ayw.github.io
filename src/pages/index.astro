---
import Layout from "../layouts/Layout.astro";
import { LINKS } from "../lib/constants";
---

<Layout
  description="Full-Stack Engineer & AI Researcher. Building high-performance systems with Rust, Java, Python, React, and PyTorch."
  title="Ei-Ayw — Full-Stack Engineer & AI Researcher"
>
  <main class="mx-auto max-w-3xl px-6 py-20">

    <!-- Header -->
    <header class="mb-20">
      <img
        alt="Ei-Ayw"
        class="w-16 h-16 rounded-full border border-gray-200 mb-6 object-cover"
        src="/avatar.jpg"
      />
      <h1 class="text-3xl font-bold tracking-tight text-slate-900">Ei-Ayw</h1>
      <p class="mt-2 text-lg text-gray-500">Full-Stack Engineer & AI Researcher.</p>
      <p class="mt-3 text-base text-gray-600 leading-relaxed max-w-xl">
        I build robust systems across the entire stack — from Rust-powered backends
        and secure sandboxes to React interfaces and deep learning pipelines.
      </p>
      <div class="mt-5 flex items-center gap-4 text-sm">
        <a class="text-gray-500 hover:text-blue-600 transition-colors" href={LINKS.github} target="_blank">
          GitHub &nearr;
        </a>
      </div>
    </header>

    <!-- Projects -->
    <section class="mt-16">
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-6">Projects</h2>

      <a class="group relative flex flex-col items-start justify-between rounded-2xl border border-gray-100 p-6 bg-white shadow-sm hover:shadow-md hover:border-gray-200 transition-all mb-4" href="https://github.com/Ei-Ayw/PocketClaw" target="_blank">
        <div class="flex items-center justify-between w-full">
          <h3 class="text-base font-semibold text-slate-900 group-hover:text-blue-600 transition-colors">PocketClaw</h3>
          <span class="text-gray-400 group-hover:text-blue-600 text-xs transition-colors">&nearr;</span>
        </div>
        <p class="mt-2 text-sm text-gray-500 leading-relaxed">High-performance cross-platform AI desktop assistant. Direct IPC to Rust core, plugin system, and security sandbox.</p>
        <div class="flex flex-wrap mt-4">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-50 text-gray-600 border border-gray-200 mr-2">Rust</span>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-50 text-gray-600 border border-gray-200 mr-2">Tauri</span>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-50 text-gray-600 border border-gray-200 mr-2">React</span>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-50 text-gray-600 border border-gray-200 mr-2">TypeScript</span>
        </div>
      </a>

      <a class="group relative flex flex-col items-start justify-between rounded-2xl border border-gray-100 p-6 bg-white shadow-sm hover:shadow-md hover:border-gray-200 transition-all mb-4" href="https://github.com/Ei-Ayw/ayw-oj-backend" target="_blank">
        <div class="flex items-center justify-between w-full">
          <h3 class="text-base font-semibold text-slate-900 group-hover:text-blue-600 transition-colors">CodingQuest OJ</h3>
          <span class="text-gray-400 group-hover:text-blue-600 text-xs transition-colors">&nearr;</span>
        </div>
        <p class="mt-2 text-sm text-gray-500 leading-relaxed">Full-stack online judge with secure code sandbox, async evaluation, multi-language support, and real-time tracking.</p>
        <div class="flex flex-wrap mt-4">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-50 text-gray-600 border border-gray-200 mr-2">Java</span>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-50 text-gray-600 border border-gray-200 mr-2">Spring Boot</span>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-50 text-gray-600 border border-gray-200 mr-2">Vue</span>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-50 text-gray-600 border border-gray-200 mr-2">Docker</span>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-50 text-gray-600 border border-gray-200 mr-2">Redis</span>
        </div>
      </a>

      <a class="group relative flex flex-col items-start justify-between rounded-2xl border border-gray-100 p-6 bg-white shadow-sm hover:shadow-md hover:border-gray-200 transition-all mb-4" href="https://github.com/Ei-Ayw/SyncPulse" target="_blank">
        <div class="flex items-center justify-between w-full">
          <h3 class="text-base font-semibold text-slate-900 group-hover:text-blue-600 transition-colors">SyncPulse</h3>
          <span class="text-gray-400 group-hover:text-blue-600 text-xs transition-colors">&nearr;</span>
        </div>
        <p class="mt-2 text-sm text-gray-500 leading-relaxed">Automated GitHub-to-Gitee repository mirroring platform with OAuth 2.0 and webhook-triggered sync.</p>
        <div class="flex flex-wrap mt-4">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-50 text-gray-600 border border-gray-200 mr-2">React</span>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-50 text-gray-600 border border-gray-200 mr-2">FastAPI</span>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-50 text-gray-600 border border-gray-200 mr-2">Celery</span>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-50 text-gray-600 border border-gray-200 mr-2">Redis</span>
        </div>
      </a>
    </section>

    <!-- Skills -->
    <section class="mt-16">
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-6">Tech & Infrastructure</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-y-5 gap-x-8">
        <div>
          <h3 class="text-xs font-medium text-gray-400 mb-2">Languages</h3>
          <ul class="text-sm text-gray-700 space-y-1">
            <li>Rust</li>
            <li>Java</li>
            <li>Python</li>
            <li>TypeScript</li>
            <li>Go</li>
          </ul>
        </div>
        <div>
          <h3 class="text-xs font-medium text-gray-400 mb-2">Frameworks</h3>
          <ul class="text-sm text-gray-700 space-y-1">
            <li>Spring Boot</li>
            <li>Vue</li>
            <li>React</li>
            <li>FastAPI</li>
          </ul>
        </div>
        <div>
          <h3 class="text-xs font-medium text-gray-400 mb-2">AI / ML</h3>
          <ul class="text-sm text-gray-700 space-y-1">
            <li>PyTorch</li>
            <li>Deep Learning</li>
            <li>RAG Pipeline</li>
          </ul>
        </div>
        <div>
          <h3 class="text-xs font-medium text-gray-400 mb-2">DevOps</h3>
          <ul class="text-sm text-gray-700 space-y-1">
            <li>Docker</li>
            <li>Kubernetes</li>
            <li>Nginx</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Engineering Notes -->
    <section class="mt-16">
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-6">Engineering Notes</h2>
      <div class="flex flex-col divide-y divide-gray-100">
        <a class="group flex items-center justify-between py-3.5 hover:text-blue-600 transition-colors" href="/notes/zeroclaw-ipc-architecture">
          <div>
            <span class="text-sm font-medium text-slate-800 group-hover:text-blue-600 transition-colors">ZeroClaw IPC Architecture: Bridging Rust and React</span>
            <span class="block text-xs text-gray-400 mt-0.5">2026-03-01</span>
          </div>
          <span class="text-gray-300 group-hover:text-blue-600 text-xs ml-4 flex-shrink-0 transition-colors">&nearr;</span>
        </a>
        <a class="group flex items-center justify-between py-3.5 hover:text-blue-600 transition-colors" href="https://github.com/Ei-Ayw/ayw-oj-backend/blob/master/SANDBOX_DESIGN.md" target="_blank">
          <div>
            <span class="text-sm font-medium text-slate-800 group-hover:text-blue-600 transition-colors">Designing a Secure, Async Code Sandbox for OJ Systems</span>
            <span class="block text-xs text-gray-400 mt-0.5">Architecture doc</span>
          </div>
          <span class="text-gray-300 group-hover:text-blue-600 text-xs ml-4 flex-shrink-0 transition-colors">&nearr;</span>
        </a>
      </div>
    </section>

    <!-- Education -->
    <section class="mt-16">
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-6">Education</h2>
      <div>
        <h3 class="text-sm font-semibold text-slate-900">Data Science & Big Data Technology</h3>
        <p class="text-sm text-gray-500 mt-0.5">B.Eng.</p>
        <p class="text-sm text-gray-600 mt-2 leading-relaxed max-w-xl">
          Focused on the intersection of AI research and full-stack engineering — building
          end-to-end systems from deep learning models to production-ready applications.
        </p>
      </div>
    </section>

    <!-- Footer -->
    <footer class="mt-20 pt-8 border-t border-gray-100">
      <p class="text-xs text-gray-400">
        &copy; 2025 Ei-Ayw
      </p>
    </footer>

  </main>
</Layout>
