---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card/index.astro";
import IntroCard from "../components/IntroCard.astro";
import ContactsCard from "../components/ContactsCard.astro";
import TimeZone from "../components/TimeZoneCard.astro";
import AboutMe from "../components/AboutMe.astro";
import Now from "../components/Now.astro";
import Globe from "../components/Globe";
---

<script>
  import { stagger, animate, type AnimationSequence } from "motion";
  import { loaderAnimation } from "../lib/constants";
  const cards = document.querySelectorAll(".card");

  const sequence = [
    loaderAnimation,
    [
      cards,
      { y: ["40%", "0%"], opacity: [0, 1] },
      {
        type: "spring",
        at: "-0.1",
        delay: stagger(0.3),
      },
    ],
  ];

  animate(sequence as AnimationSequence);
</script>

<Layout
  description="Full-Stack Engineer & AI Researcher. Building robust systems and exploring AI/ML frontiers with Rust, Java, Python, React, Docker, and PyTorch."
  title="Ei-Ayw - Full-Stack Engineer & AI Researcher"
>
  <main
    class="text-white m-auto p-2 grid gap-2 max-w-6xl overflow-hidden relative w-full sm:p-4 sm:gap-2 md:grid-cols-2 md:gap-3 md:p-6 lg:h-screen lg:grid-rows-8 lg:grid-cols-4 lg:gap-4 lg:max-h-[800px]"
  >
    <IntroCard />
    <AboutMe />
    <ContactsCard />
    <TimeZone />
    <Now />
    <Card
      colorText="text-neutral-900"
      colSpan="md:col-span-1"
      rowSpan="md:row-span-1"
      title="Based in China"
    >
      <div class="h-full w-full absolute inset-0 -z-10">
        <Globe client:load />
      </div>
    </Card>
    <Card
      colSpan="md:col-span-1"
      rowSpan="md:row-span-2 flex gap-1"
      title="Projects"
    >
      <div class="flex flex-col gap-1">
        <a class="list-none w-full text-neutral-100 hover:text-primary-400 ease-in-out transition-colors border-b-neutral-400 border-dashed border-b-1 my-0 decoration-none" href="https://github.com/Ei-Ayw" target="_blank">
          <p class="inline-block text-xs font-bold">PocketClaw</p>
          <p class="text-xs text-gray-400">Lightweight web scraper framework</p>
        </a>
        <a class="list-none w-full text-neutral-100 hover:text-primary-400 ease-in-out transition-colors border-b-neutral-400 border-dashed border-b-1 my-0 decoration-none" href="https://github.com/Ei-Ayw" target="_blank">
          <p class="inline-block text-xs font-bold">CodingQuest OJ</p>
          <p class="text-xs text-gray-400">Online judge platform</p>
        </a>
        <a class="list-none w-full text-neutral-100 hover:text-primary-400 ease-in-out transition-colors border-b-neutral-400 border-dashed border-b-1 my-0 decoration-none" href="https://github.com/Ei-Ayw" target="_blank">
          <p class="inline-block text-xs font-bold">SyncPulse</p>
          <p class="text-xs text-gray-400">Real-time data sync engine</p>
        </a>
        <a class="list-none w-full text-neutral-100 hover:text-primary-400 ease-in-out transition-colors border-b-neutral-400 border-dashed border-b-1 my-0 decoration-none" href="https://github.com/Ei-Ayw" target="_blank">
          <p class="inline-block text-xs font-bold">CryptoSage</p>
          <p class="text-xs text-gray-400">Crypto analytics toolkit</p>
        </a>
        <a class="list-none w-full text-neutral-100 hover:text-primary-400 ease-in-out transition-colors border-b-neutral-400 border-dashed border-b-1 my-0 decoration-none" href="https://github.com/Ei-Ayw" target="_blank">
          <p class="inline-block text-xs font-bold">DFMamba</p>
          <p class="text-xs text-gray-400">Deep learning research model</p>
        </a>
        <a class="list-none w-full text-neutral-100 hover:text-primary-400 ease-in-out transition-colors border-b-neutral-400 border-dashed border-b-1 my-0 decoration-none" href="https://github.com/Ei-Ayw" target="_blank">
          <p class="inline-block text-xs font-bold">KnowledgeForge</p>
          <p class="text-xs text-gray-400">Knowledge graph builder</p>
        </a>
      </div>
    </Card>
    <Card colSpan="md:col-span-1" rowSpan="md:row-span-1">
      <p class="text-xs">
        &copy; 2025 &middot; Crafted with <a
          class="text-red-500"
          href="https://astro.build/"
          target="_blank">Astro</a
        > by Ei-Ayw.
      </p>
    </Card>
  </main>
</Layout>
