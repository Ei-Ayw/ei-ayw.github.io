---
const { frontmatter } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width" name="viewport" />
    <link href="/favicon.ico" rel="icon" type="image/x-icon" />
    <title>{frontmatter.title} — Ei-Ayw</title>
    <meta content={frontmatter.description || frontmatter.title} name="description" />
  </head>
  <body class="bg-white text-gray-800 antialiased">
    <main class="mx-auto max-w-2xl px-6 py-16">
      <a class="text-sm text-gray-400 hover:text-blue-600 transition-colors" href="/">&larr; Back</a>
      <header class="mt-8 mb-12">
        <h1 class="text-2xl font-bold tracking-tight text-slate-900">{frontmatter.title}</h1>
        {frontmatter.date && (
          <p class="mt-2 text-sm text-gray-400">{frontmatter.date}</p>
        )}
      </header>
      <article class="prose prose-slate prose-sm max-w-none">
        <slot />
      </article>
      <footer class="mt-16 pt-8 border-t border-gray-100">
        <a class="text-sm text-gray-400 hover:text-blue-600 transition-colors" href="/">&larr; Back to Home</a>
      </footer>
    </main>
  </body>
</html>

<style is:global>
  body {
    margin: 0;
    font-family: "Inter", system-ui, -apple-system, sans-serif;
    -webkit-font-smoothing: antialiased;
  }
  pre {
    background-color: #1E293B !important;
    color: #E2E8F0 !important;
    border-radius: 8px;
    padding: 1rem;
    overflow-x: auto;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.85em;
    line-height: 1.7;
  }
  pre code {
    background: none !important;
    padding: 0 !important;
    color: inherit !important;
  }
</style>
